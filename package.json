{
  "name": "ahava-healthcare",
  "version": "1.0.0",
  "description": "Ahava Healthcare - Full-stack healthcare platform for South Africa - patient bookings, nurse home visits, doctor oversight",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "workspace"
  ],
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "pnpm -r run build",
    "build:frontend": "pnpm --filter workspace build",
    "build:capacitor": "vite build --config vite.capacitor.config.ts",
    "start:frontend": "pnpm --filter workspace start",
    "dev": "pnpm -r --parallel run dev",
    "dev:api": "pnpm --filter @ahava-healthcare/api dev",
    "test": "pnpm -r run test",
    "test:backend": "pnpm --filter @ahava-healthcare/api test",
    "lint": "pnpm -r run lint",
    "lint:fix": "pnpm -r run lint:fix",
    "type-check": "pnpm -r run type-check",
    "clean": "pnpm -r run clean",
    "prisma:generate": "pnpm --filter @ahava-healthcare/api prisma:generate",
    "prisma:migrate": "pnpm --filter @ahava-healthcare/api prisma:migrate",
    "prisma:seed": "pnpm --filter @ahava-healthcare/api prisma:seed",
    "seed:mock-patients": "pnpm --filter @ahava-healthcare/api seed:mock-patients",
    "seed:from-synthea": "pnpm --filter @ahava-healthcare/api seed:from-synthea",
    "synthea:run-and-seed": "node scripts/run-synthea-and-seed.js",
    "load-test:patient-pipeline": "node scripts/load-test-patient-pipeline.js",
    "test:early-warning": "node scripts/run-early-warning-test.js",
    "test:services": "node scripts/test-services.js",
    "db:reset": "pnpm --filter @ahava-healthcare/api db:reset"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.10.0",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "postcss": "^8.5.8",
    "prettier": "^3.1.0",
    "puppeteer": "^24.37.4",
    "tailwindcss": "^4",
    "typescript": "^5.3.0",
    "vite": "^8.0.1"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/device": "^8.0.1",
    "capacitor-health": "^8.0.1",
    "chart.js": "^4.5.1",
    "lucide-react": "^0.577.0",
    "next": "^15.5.9",
    "react": "19.1.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "19.1.0",
    "react-router": "^7.13.1",
    "react-router-dom": "^7.13.1"
  }
}
